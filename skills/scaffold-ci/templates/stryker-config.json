{
  "stryker-config": {
    "solution": "YourSolution.sln",
    "project": "src/Your.Project/Your.Project.csproj",
    "test-projects": [
      "tests/Your.Project.Tests/Your.Project.Tests.csproj"
    ],
    "reporters": [
      "progress",
      "html",
      "json"
    ],
    "report-file-name": "mutation-report",
    "mutation-level": "Standard",
    "coverage-analysis": "off",
    "test-runner": "mtp",
    "concurrency": 4,
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "test-case-filter": "Category!=Integration",
    "mutate": [
      "**/*.cs"
    ]
  }
}
